            { "id": "supine-twist", "duration": 45 },
            { "id": "supine-twist", "duration": 45, "note": "Other side" },
            { "id": "pigeon", "duration": 60 },
            { "id": "pigeon", "duration": 60, "note": "Other side" }
          ]
        },
        {
          "name": "Drain",
          "exercises": [
            { "id": "legs-up-wall", "duration": 180 }
          ]
        }
      ]
    }
  ]
}
