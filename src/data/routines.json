            { "id": "supine-twist", "duration": 60 },
            { "id": "supine-twist", "duration": 60, "note": "Other side" },
            { "id": "pigeon", "duration": 60 },
            { "id": "pigeon", "duration": 60, "note": "Other side" }
          ]
        },
        {
